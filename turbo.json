{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"],
      "env": [
        "CLERK_SECRET_KEY",
        "CLERK_WEBHOOK_SECRET",
        "CLERK_WEBHOOK_SIGNING_SECRET",
        "NEXT_PUBLIC_SUPABASE_URL",
        "SUPABASE_SERVICE_ROLE_KEY",
        "SUPABASE_MANAGEMENT_API_TOKEN",
        "BASEHUB_TOKEN",
        "BORROWER_SSN_ENC_KEY",
        "N8N_SSN_KEY",
        "OPENAI_API_KEY",
        "AI_GATEWAY_API_KEY",
        "LIVEBLOCKS_SECRET_KEY",
        "LIVEBLOCKS_WEBHOOK_SECRET",
        "LIVEBLOCKS_APPRAISAL_WEBHOOK_SECRET",
        "TIPTAP_PRO_TOKEN",
        "V0_API_KEY",
        "DOCUMENSO_API_KEY",
        "RESEND_API_KEY",
        "APPRAISAL_CHAT_API_KEY"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "format": {},
    "format:fix": {},
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "test:e2e": {
      "cache": false
    },
    "clean": {}
  }
}