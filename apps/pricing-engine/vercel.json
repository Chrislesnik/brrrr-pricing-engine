{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install",
  "functions": {
    "src/app/api/pdf/render/route.ts": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/docs",
      "destination": "https://brrrrloans.mintlify.dev/docs"
    },
    {
      "source": "/docs/:match*",
      "destination": "https://brrrrloans.mintlify.dev/docs/:match*"
    },
    {
      "source": "/resources",
      "destination": "https://brrrrloans.mintlify.dev/resources"
    },
    {
      "source": "/resources/:match*",
      "destination": "https://brrrrloans.mintlify.dev/resources/:match*"
    }
  ]
}
