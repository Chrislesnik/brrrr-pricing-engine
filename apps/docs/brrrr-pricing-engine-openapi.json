{
  "openapi": "3.0.3",
  "info": {
    "title": "BRRRR Pricing Engine API",
    "version": "1.0.0",
    "description": "REST API for managing deals, loans, borrowers, entities, scenarios, and more within the BRRRR Pricing Engine platform."
  },
  "servers": [
    {
      "url": "https://api.example.com",
      "description": "API server"
    }
  ],
  "tags": [
    {
      "name": "Deals",
      "description": "Create and manage lending deals."
    },
    {
      "name": "Loans",
      "description": "View, update, and archive loans."
    },
    {
      "name": "Applications",
      "description": "Track loan applications across the pipeline."
    },
    {
      "name": "Borrowers",
      "description": "Search, create, and manage borrower profiles."
    },
    {
      "name": "Entities",
      "description": "Manage LLCs, Trusts, and other legal entities."
    },
    {
      "name": "Scenarios",
      "description": "Model pricing scenarios for loans."
    },
    {
      "name": "Programs",
      "description": "View lending program configurations."
    },
    {
      "name": "Appraisals",
      "description": "Manage property appraisal orders."
    },
    {
      "name": "Documents",
      "description": "Work with document templates."
    },
    {
      "name": "Credit Reports",
      "description": "Pull and view credit reports."
    },
    {
      "name": "Background Reports",
      "description": "Run background checks on borrowers and entities."
    },
    {
      "name": "Pipeline",
      "description": "Retrieve pipeline-level analytics."
    },
    {
      "name": "Signature Requests",
      "description": "Track e-signature status for deals."
    }
  ],
  "paths": {
    "/api/deals": {
      "get": {
        "operationId": "list-deals",
        "summary": "List deals",
        "description": "Returns a paginated list of deals visible to the authenticated API key's organization.",
        "tags": [
          "Deals"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "example": {
                    "deals": [
                      {
                        "id": "deal_01HXYZ",
                        "heading": "123 Main St – Purchase",
                        "created_at": "2025-06-15T10:30:00Z"
                      }
                    ]
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "create-deal",
        "summary": "Create a deal",
        "description": "Creates a new deal with the supplied inputs. Each input is identified by its input_id and input_type.",
        "tags": [
          "Deals"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "example": {
                    "ok": true,
                    "deal": {
                      "id": "deal_01HXYZ"
                    }
                  }
                }
              }
            }
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "example": {
                  "deal_inputs": [
                    {
                      "input_id": "property_address",
                      "input_type": "text",
                      "value": "123 Main St, Austin TX 78701"
                    },
                    {
                      "input_id": "purchase_price",
                      "input_type": "number",
                      "value": 450000
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/loans/list": {
      "get": {
        "operationId": "list-loans",
        "summary": "List loans",
        "description": "Returns all loans visible to the organization.",
        "tags": [
          "Loans"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "example": [
                    {
                      "id": "loan_01",
                      "displayId": "LN-0042",
                      "label": "Fix & Flip – 123 Main St"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/loans/{id}": {
      "patch": {
        "operationId": "update-loan",
        "summary": "Update a loan",
        "description": "Updates an existing loan's status or triggers an action (e.g. submit, approve).",
        "tags": [
          "Loans"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "example": {
                    "ok": true
                  }
                }
              }
            }
          }
        },
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Loan ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "example": {
                  "status": "approved",
                  "action": "approve"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "archive-loan",
        "summary": "Archive a loan",
        "description": "Soft-deletes a loan by moving it to the archive.",
        "tags": [
          "Loans"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "example": {
                    "ok": true
                  }
                }
              }
            }
          }
        },
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Loan ID",
            "schema": {
              "type": "string"
            }
          }
        ]
      }
    },
    "/api/applications/list": {
      "get": {
        "operationId": "list-applications",
        "summary": "List applications",
        "description": "Returns all loan applications across the organization pipeline.",
        "tags": [
          "Applications"
        ],
        "security": [
          {
            "bearerAuth": []
