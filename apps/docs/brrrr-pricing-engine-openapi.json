                "schema": {
                  "type": "object",
                  "example": {
                    "items": [
                      {
                        "id": "ent_01",
                        "entity_name": "Acme Holdings LLC",
                        "entity_type": "llc"
                      }
                    ],
                    "ownersMap": {
                      "ent_01": [
                        {
                          "borrower_id": "brw_01",
