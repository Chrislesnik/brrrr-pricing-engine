                        "signingProgressPct": 75
                      }
                    ]
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/applicants/borrowers": {
      "get": {
        "operationId": "search-borrowers",
        "summary": "Search borrowers",
        "description": "Full-text search across borrowers by name, email, or ID. Optionally filter by entity.",
        "tags": [
          "Borrowers"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "example": {
                    "borrowers": [
                      {
                        "id": "brw_01",
                        "first_name": "Jane",
                        "last_name": "Smith",
                        "email": "jane@example.com"
                      }
                    ]
                  }
                }
              }
            }
          }
        },
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": false,
            "description": "Search query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "entityId",
            "in": "query",
            "required": false,
            "description": "Filter by entity ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "includeIds",
            "in": "query",
            "required": false,
            "description": "Comma-separated IDs to always include",
            "schema": {
              "type": "string"
            }
          }
        ]
      },
      "post": {
        "operationId": "create-borrower",
        "summary": "Create a borrower",
        "description": "Creates a new borrower profile attached to the organization.",
        "tags": [
          "Borrowers"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "example": {
                    "ok": true,
                    "borrower": {
                      "id": "brw_01"
                    }
                  }
                }
              }
            }
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "example": {
                  "first_name": "Jane",
                  "last_name": "Smith",
                  "email": "jane@example.com",
                  "fico_score": 740,
                  "phone": "+15125551234"
                }
              }
            }
          }
        }
      }
    },
    "/api/applicants/borrowers/list": {
      "get": {
        "operationId": "list-borrowers-pipeline",
