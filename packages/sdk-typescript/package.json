{
  "name": "@repo/sdk-typescript",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "generate": "openapi-generator-cli generate -i ../api-contract/dist/openapi.json -g typescript-fetch -o src --additional-properties=supportsES6=true,typescriptThreePlus=true,withInterfaces=true",
    "lint": "eslint --max-warnings 0",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {},
  "devDependencies": {
    "@openapitools/openapi-generator-cli": "^2.15.0",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "eslint": "^9",
    "typescript": "^5.7.3"
  }
}
